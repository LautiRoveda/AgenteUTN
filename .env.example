# Copiá este archivo a `.env` y completá tus credenciales.
# El script `utn_monitor_v3.py` falla con error claro si alguna falta.
# NUNCA commitees tu .env: ya está en .gitignore — dejalo así.

# ─── UTN FRC Autogestión ─────────────────────────────────────────────────────
# Legajo (el número con el que entrás a Autogestión).
UTN_USER=

# Contraseña de Autogestión UTN.
UTN_PASS=

# Dominio del campus. Para FRC siempre es "sistemas".
# Esta variable es opcional; si no la setés, se usa "sistemas" por defecto.
UTN_DOMAIN=sistemas

# ─── Telegram ────────────────────────────────────────────────────────────────
# Token del bot que te dio @BotFather (formato: <numeros>:<letras_y_simbolos>).
TELEGRAM_TOKEN=
